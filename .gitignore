# Root backup repo — ignore OS and IDE cruft
.DS_Store
Thumbs.db
*.log

# Dependencies and build output inside backup copies
backups/projects/**/node_modules/
backups/projects/**/.next/
backups/projects/**/out/
backups/projects/**/.vercel/
backups/projects/cardsaas/.playwright-cli/

# n8n-prompt-manager: exclude large binaries (kept in sync-sources)
backups/projects/n8n-prompt-manager/*.zip
backups/projects/n8n-prompt-manager/*.app
backups/projects/n8n-prompt-manager/**/*.zip
backups/projects/n8n-prompt-manager/**/*.app
backups/projects/n8n-prompt-manager/**/__pycache__
backups/projects/n8n-prompt-manager/app.log
backups/projects/n8n-prompt-manager/windows-package

# pharmatech: large archives and build artifacts
backups/projects/pharmatech/*.zip
backups/projects/pharmatech/.playwright-cli/
backups/projects/pharmatech/pharmatech-upload/
